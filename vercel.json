{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd api && npm install",
  "framework": null,
  "functions": {
    "api/**/*.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/transcribe",          "destination": "/api/transcribe" },
    { "source": "/api/suggestions/expand",  "destination": "/api/suggestions/expand" },
    { "source": "/api/suggestions",         "destination": "/api/suggestions" },
    { "source": "/api/chat",                "destination": "/api/chat" },
    { "source": "/((?!api/).*)",            "destination": "/index.html" }
  ]
}