{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "env": {
    "GROQ_API_KEY": "@groq-api-key",
    "OPENAI_API_KEY": "@openai-api-key", 
    "OPENROUTER_API_KEY": "@openrouter-api-key"
  },
  "functions": {
    "backend/server.js": {
      "maxDuration": 30
    }
  }
}
